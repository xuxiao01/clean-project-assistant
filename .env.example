# 服务端口（可选，默认 3000）
PORT=3000

# PostgreSQL（pgvector，必填），例如：
# DATABASE_URL=postgresql://用户名@localhost:5432/数据库名
DATABASE_URL=

# 当前单活 provider（可选，默认 zhipu）：zhipu | gemini
LLM_PROVIDER=zhipu

# --------------------
# Zhipu 配置（provider=zhipu 时必填）
# --------------------
ZHIPU_API_KEY=

# 可选：智谱模型 id，默认 glm-4-flash-250414（免费）
# 兼容旧字段 ZHIPU_MODEL，优先使用 ZHIPU_CHAT_MODEL
# ZHIPU_CHAT_MODEL=glm-4-flash-250414

# 可选：文本嵌入模型，默认 embedding-2（1024 维）；可改为 embedding-3 等
# ZHIPU_EMBEDDING_MODEL=embedding-2

# --------------------
# Gemini 配置（provider=gemini 时必填 GEMINI_API_KEY）
# --------------------
# GEMINI_API_KEY=
# GEMINI_CHAT_MODEL=gemini-1.5-flash
# GEMINI_EMBEDDING_MODEL=text-embedding-004
# 重要约束：代码会显式请求 outputDimensionality=1024，禁止使用默认 embedding 维度。
