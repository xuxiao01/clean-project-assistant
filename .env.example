# 服务端口（可选，默认 3000）
PORT=3000

# PostgreSQL（pgvector，必填），例如：
# DATABASE_URL=postgresql://用户名@localhost:5432/数据库名
DATABASE_URL=

# 智谱 AI API Key（必填，见 https://open.bigmodel.cn/usercenter/apikeys）
ZHIPU_API_KEY=

# 可选：智谱模型 id，默认 glm-4-flash-250414（免费）
# ZHIPU_MODEL=glm-4-flash-250414

# 可选：文本嵌入模型，默认 embedding-2（1024 维）；可改为 embedding-3 等
# ZHIPU_EMBEDDING_MODEL=embedding-2
